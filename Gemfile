source "https://rubygems.org"

# Upgrade to Jekyll 4
gem "jekyll", "~> 4.3"

# GitHub Pages usually includes these plugins by default. 
# Since you're no longer using the 'github-pages' gem, you must list them manually:
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jekyll-seo-tag"
  gem "jekyll-paginate"
  gem "jekyll-relative-links"
  gem "jekyll-remote-theme"
end

# Jekyll 4 requires webrick for local serving on Ruby 3+
gem "webrick"
